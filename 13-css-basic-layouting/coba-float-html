      similique ipsa voluptatem, hic eaque!
    </p>
    
  </section>

  <section>
    <h2>2. Layout 3 Kolom</h2>
    <div class="kolom-container">
      <div class="kolom">
        <h3>Kolom 1</h3>
        <p>ini kolom sebelah kiri</p>
      </div>
      <div class="kolom">
        <h3>Kolom 2</h3>
        <p>ini kolom tengah</p>
      </div>
      <div class="kolom">
        <h3>Kolom 3</h3>
        <p>ini kolom sebelah kanan</p>
      </div>
    </div>
  </section>

  <section>
    <h2>3. Image Gallery</h2>
    <div class="gallery-container clearfix">
      <div class="gallery-item">
        <img src="https://picsum.photos/id/30/150/150" alt="Gallery 1">
      </div>
      <div class="gallery-item">
        <img src="https://picsum.photos/id/40/150/150" alt="Gallery 2">
