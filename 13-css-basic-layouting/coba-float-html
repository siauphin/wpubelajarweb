<!DOCTYPE html>
<html lang="id">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Latihan CSS Float</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', sans-serif;
      line-height: 1.6;
      color: #333;
      background-color: #b28e2d;
      padding: 40px;
    }

    h1 {
      text-align: center;
      margin-bottom: 50px;
    }

    section {
      background: white;
      padding: 30px;
      margin-bottom: 50px;
      border-radius: 12px;
      border: 1px solid #ddd;
    }

    h2 {
      margin-bottom: 20px;
      color: #1e40af;
      border-bottom: 2px solid #e5e7eb;
      padding-bottom: 10px;
    }

    .text-wrapping img {
      margin-right: 20px;
      margin-bottom: 10px;
      border: 4px solid #fff;
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    }

    .img-left {
        float: left;
    }

    .img-right {
        float: right;
    }

    .clearfix::after {
        content: "";
        display: table;
        clear: both;
    }

    .kolom-container {
      background-color: #f8fafc;
      padding: 10px;
      border-radius: 8px;
      overflow: auto;
    }

    .kolom {
      float: left;
      width: 31.33%;
      margin: 1%;
      padding: 20px;
      background-color: #dbeafe;
      border: 1px solid #bfdbfe;
      min-height: 200px;
      text-align: center;
    }

    .gallery-container {
      padding: 10px;
      background-color: #f8fafc;
      
    }

    .gallery-item {
      float: left;
      width: 150px;
      height: 150px;
      margin: 10px;
      background-color: #eee;
      border: 2px solid #ddd;
    }

    .gallery-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .footer-note {
      background-color: #1e293b;
      color: #f1f5f9;
      padding: 20px;
      border-radius: 8px;
      margin-top: 50px;
    }
  </style>
</head>

<body>

  <h1>Eksperimen CSS Float</h1>

  <section class="text-wrapping clearfix">
    <h2>1. Text Wrapping</h2>
    <img src="https://picsum.photos/id/10/200/200" alt="Gambar 1" class="img-left">
